rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { 
      allow read, write: if false; 
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true; 
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    function isValidUser(data, isCreate) {
      return data.keys().hasAll(isCreate ? ['email', 'points', 'createdAt'] : [])
        && data.email is string && data.email.size() <= 100
        && data.points is int
        && (isCreate ? data.createdAt is string : true);
    }

    match /users/{userId} {
      allow get: if true; // Allows leaderboard reading without PII exposure assuming email gets stripped out or is acceptable as public. PII should strictly be isolated, but for this app it's a simple profile.
      allow list: if true;

      allow create: if isOwner(userId)
        && isValidUser(incoming(), true)
        && incoming().points == 0;

      allow update: if isOwner(userId)
        && isValidUser(incoming(), false)
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'fcmTokens', 'updatedAt'])
        && incoming().updatedAt is string
        || isAdmin();

      allow delete: if isAdmin();
    }

    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    function isValidPrediction(data, isCreate) {
      return data.keys().hasAll(isCreate ? ['userId', 'matchId', 'predictedHomeScore', 'predictedAwayScore', 'createdAt'] : [])
        && data.userId is string && data.userId == request.auth.uid
        && data.matchId is string
        && data.predictedHomeScore is int
        && data.predictedAwayScore is int
        && data.predictedHomeScore >= 0 && data.predictedHomeScore <= 50
        && data.predictedAwayScore >= 0 && data.predictedAwayScore <= 50
        && (!('pointsEarned' in data) || data.pointsEarned == 0 || isAdmin())
        && (!('isDefinitive' in data) || data.isDefinitive is bool)
        && (isCreate ? data.createdAt is string : true);
    }

    match /predictions/{predictionId} {
      // Anyone can see predictions
      allow read: if true;

      // Create only if match is pending
      allow create: if isValidId(predictionId) 
        && isOwner(incoming().userId)
        && isValidPrediction(incoming(), true)
        && exists(/databases/$(database)/documents/matches/$(incoming().matchId))
        && get(/databases/$(database)/documents/matches/$(incoming().matchId)).data.status == 'pending';

      // Update allowed only if match is pending and existing prediction is not definitive (unless admin updating points)
      allow update: if isOwner(existing().userId)
        && isOwner(incoming().userId)
        && incoming().userId == existing().userId
        && incoming().matchId == existing().matchId
        && isValidPrediction(incoming(), false)
        && (!('isDefinitive' in existing()) || existing().isDefinitive == false)
        && incoming().diff(existing()).affectedKeys().hasOnly(['predictedHomeScore', 'predictedAwayScore', 'isDefinitive', 'updatedAt'])
        && incoming().updatedAt is string
        && get(/databases/$(database)/documents/matches/$(incoming().matchId)).data.status == 'pending'
        || isAdmin(); 

      allow delete: if isOwner(existing().userId) 
        && (!('isDefinitive' in existing()) || existing().isDefinitive == false)
        && get(/databases/$(database)/documents/matches/$(existing().matchId)).data.status == 'pending'
        || isAdmin();
    }
  }
}
